# ─────────────────────────────────────────────────────────────────────────────
# NetMapServer — Environment variables reference
#
# Copy this file to .env for local development (never commit .env).
# On the server these values live in /etc/netmap/netmap-server.env (mode 640).
# In GitHub Actions add them as Repository Secrets (Settings → Secrets).
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────

# TCP port NetMapServer listens on (Caddy reverse-proxies to this).
PORT=8092

# Bind address. Keep 127.0.0.1 in production (Caddy is the public edge).
# Set to 0.0.0.0 only for direct local testing without a reverse proxy.
BIND_HOST=127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────

# Absolute or relative path to the SQLite database file.
DB_PATH=/opt/netmap/data/netmap_data.db

# ── Authentication & secrets ─────────────────────────────────────────────────

# API key required for all telemetry ingestion endpoints (X-API-Key header).
# Generate with: openssl rand -hex 20
# REQUIRED in production — server refuses to start with the default value.
API_KEY=change-me-in-production

# Secret passed as ?secret= to POST /api/auth/setup (one-time admin bootstrap).
# Generate with: openssl rand -hex 32
# REQUIRED in production — the setup endpoint is blocked until this is set.
SETUP_SECRET=change-me-in-production

# Initial admin account seeded on first startup (only when no users exist yet).
# Leave blank after the first boot — re-seeding is a no-op but leaking these
# in logs is avoided by unsetting them.
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login

# ── Caddy / public network ────────────────────────────────────────────────────

# Public domain Caddy serves. Caddy will obtain a TLS certificate automatically.
NETMAP_DOMAIN=track.yourserver.com

# External port for the OTA web server (ESP32 firmware connects here).
OTA_PORT=9443

# Internal port Flask/Gunicorn listens on (OTA backend).
OTA_INTERNAL_PORT=9000

# ── OTA server internal URL (used by SwiftServer → OTA proxy calls) ──────────

# Full URL of the internal OTA Flask service, as seen by NetMapServer.
OTA_INTERNAL_URL=http://127.0.0.1:9000

# ── Proxy / security ─────────────────────────────────────────────────────────

# Comma-separated list of additional trusted proxy IPs (beyond 127.0.0.1/::1).
# Example: TRUSTED_PROXY_IPS=10.0.0.1,10.0.0.2
TRUSTED_PROXY_IPS=

# ── Logging ──────────────────────────────────────────────────────────────────

# Minimum log level: trace | debug | info | notice | warning | error | critical
LOG_LEVEL=info

# Path for the security-event append-only log file.
SECURITY_EVENT_LOG_PATH=/var/log/netmap/security_events.log

# Number of days to retain security events in the database.
SECURITY_EVENT_RETENTION_DAYS=90

# ── Telemetry integrity ───────────────────────────────────────────────────────

# How often (seconds) the integrity checker runs. Minimum 60.
TELEMETRY_INTEGRITY_INTERVAL_SEC=900

# Lookback window (seconds) the integrity checker examines. Minimum 60.
TELEMETRY_INTEGRITY_LOOKBACK_SEC=900

# ── GitHub Actions deploy (server-only secrets — never commit real values) ────

# SSH username on the server (the user that has SSH access).
DEPLOY_USER=phil

# SSH hostname or IP address of the server.
DEPLOY_HOST=your-server.com

# SSH private key with access to DEPLOY_HOST.
# Generate with: ssh-keygen -t ed25519 -C "github-actions-deploy"
# Add the public key to ~/.ssh/authorized_keys on the server.
# Paste the private key into GitHub → Settings → Secrets → DEPLOY_SSH_KEY.
DEPLOY_SSH_KEY=
