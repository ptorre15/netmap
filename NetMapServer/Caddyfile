# NetMap Server — Caddy reverse proxy with automatic HTTPS
#
# Prerequisites:
#   brew install caddy
#   sudo caddy run --config Caddyfile --adapter caddyfile
#
# Box NAT rules required:
#   Port 80  TCP  →  <mac-local-ip>:80   (Let's Encrypt HTTP challenge)
#   Port 443 TCP  →  <mac-local-ip>:443  (HTTPS traffic)
#
# Domain: 92-137-172-240.nip.io resolves automatically to 92.137.172.240
# No DNS configuration needed — nip.io handles it.
#
# For local testing only (no public domain), replace the domain with:
#   localhost:8443
92-137-172-240.nip.io {
	# Proxy everything to the Vapor server
	reverse_proxy localhost:8092 {
		# Replace any client-supplied XFF chain with the real peer seen by Caddy.
		header_up X-Forwarded-For {remote_host}
	}

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://unpkg.com https://tile.openstreetmap.org https://*.tile.openstreetmap.org; connect-src 'self' https://router.project-osrm.org https://*.tile.openstreetmap.org; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		-Server
	}

	# Compress responses
	encode gzip zstd

	# No browser cache for local JS/CSS so fixes are picked up immediately
	@localAssets path *.js *.css
	header @localAssets Cache-Control "no-store, no-cache, must-revalidate"

	# Logging
	log {
		output file /var/log/caddy/netmap_access.log {
			roll_size 100mb
			roll_keep 5
			roll_keep_for 720h
		}
		format json
	}
}

# ── Local development variant (no public domain needed) ──────────────────────
# Uncomment the block below and comment out the block above to test HTTPS locally:
#
# localhost:8443 {
#     tls internal
#     reverse_proxy localhost:8092
#     encode gzip
# }
