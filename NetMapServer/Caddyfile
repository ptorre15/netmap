# NetMap Server — Caddy reverse proxy with automatic HTTPS
#
# Prerequisites:
#   brew install caddy          (macOS)
#   apt install caddy           (Debian/Ubuntu)
#
# Usage:
#   caddy run --config Caddyfile --adapter caddyfile
#
# Replace YOUR_DOMAIN with your actual domain (e.g. netmap.example.com).
# Caddy will automatically obtain and renew a Let's Encrypt certificate.
#
# For local testing with a self-signed cert, replace the domain with:
#   localhost:8443
# and run:
#   caddy run --config Caddyfile --adapter caddyfile

YOUR_DOMAIN {
    # Proxy everything to the Vapor server
    reverse_proxy localhost:8765

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    # Compress responses
    encode gzip zstd

    # Logging
    log {
        output file /var/log/caddy/netmap_access.log {
            roll_size    100mb
            roll_keep    5
            roll_keep_for 720h
        }
        format json
    }
}

# ── Local development variant (no public domain needed) ──────────────────────
# Uncomment the block below and comment out the block above to test HTTPS locally:
#
# localhost:8443 {
#     tls internal
#     reverse_proxy localhost:8765
#     encode gzip
# }
